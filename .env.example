BOT_HOST=127.0.0.1
BOT_PORT=8080
ONEBOT_ACCESS_TOKEN=change-this-token
BOT_QQ=123456789
ADMIN_USERS=123456789
GROUP_WHITELIST=987654321
DATABASE_PATH=data/rolebot.sqlite3
PERSONA_VARIANT=dialect
PERSONA_PATH=personas/default.yaml

MODEL_API_BASE=https://api.openai.com/v1
MODEL_API_KEY=replace-with-api-key
MODEL_NAME=gpt-4.1-mini
MODEL_TIMEOUT_SECONDS=20
MAX_OUTPUT_CHARS=40
DEFAULT_RANDOM_REPLY_PROBABILITY=3
KEYWORDS=重岳,岳饼,大哥
SENSITIVE_WORDS=

TAVILY_API_KEY=
TAVILY_API_BASE=https://api.tavily.com
SEARCH_MAX_RESULTS=5
SEARCH_TIMEOUT_SECONDS=10
SEARCH_COOLDOWN_SECONDS=0
TOOLS_ENABLE_SEARCH=true
TOOLS_ENABLE_PERSONA_SOURCES=true
TOOLS_ENABLE_TIME=true

TTS_ENABLED=false
TTS_BACKEND=generic
TTS_API_URL=http://127.0.0.1:5005
TTS_API_KEY=
TTS_MODEL=cosyvoice-v2
TTS_AUDIO_FORMAT=wav
TTS_TIMEOUT_SECONDS=20
TTS_TRIGGER_KEYWORDS=语音,说句话,念一下,用你的声音
TTS_MAX_CHARS=80
TTS_COOLDOWN_SECONDS=0
TTS_CACHE_DIR=data/voice_cache
TTS_SPEAKER=chongyue
TTS_STYLE=沉稳自然，武汉话日常短句，连贯不逐字
TTS_DIALECT_HINT=武汉话
TTS_REF_AUDIO_PATH=
TTS_PROMPT_TEXT=
TTS_PROMPT_LANG=zh
TTS_TEXT_LANG=zh

FOLLOWUP_WINDOW_SECONDS=90
FOLLOWUP_TRIGGER_KEYWORDS=you,what do you think,reply,chongyue,yuebing
